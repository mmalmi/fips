# Copy this file to /etc/fips/fips-health-probe.env, set the target, then
# enable fips-healthcheck.timer. The target may be this host's daemon identity
# when its public WebRTC path is expected to support a same-host probe.
FIPS_HEALTH_TARGET_NPUB=npub1replace_with_the_target_identity

# Stable probe identity used when the target enforces configured-peer or
# open-discovery admission. Protect this file as a secret (root:root 0600),
# and add the corresponding npub to the target daemon's `peers` list.
# FIPS_HEALTH_SECRET=nsec1replace_with_a_generated_probe_identity

# Optional whitespace-separated override. Defaults to FIPS relay defaults.
# FIPS_HEALTH_RELAYS=wss://relay.example wss://another-relay.example

# Optional probe tuning.
# FIPS_HEALTH_TIMEOUT_SECONDS=25
# FIPS_HEALTH_APP=fips-overlay-v1
