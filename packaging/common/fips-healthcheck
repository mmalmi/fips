#!/bin/sh
set -eu

PROBE=${FIPS_HEALTH_PROBE:-$(command -v fips-health-probe || true)}
TARGET_NPUB=${FIPS_HEALTH_TARGET_NPUB:-}
TIMEOUT_SECONDS=${FIPS_HEALTH_TIMEOUT_SECONDS:-25}
APP=${FIPS_HEALTH_APP:-fips-overlay-v1}

if [ -z "$PROBE" ]; then
    echo "fips-healthcheck: fips-health-probe not found" >&2
    exit 1
fi

if [ -z "$TARGET_NPUB" ]; then
    echo "fips-healthcheck: FIPS_HEALTH_TARGET_NPUB is not configured" >&2
    exit 1
fi

set -- --target-npub "$TARGET_NPUB" --timeout-seconds "$TIMEOUT_SECONDS" --app "$APP"
for relay in ${FIPS_HEALTH_RELAYS:-}; do
    set -- "$@" --relay "$relay"
done

outer_timeout=$((TIMEOUT_SECONDS + 8))
timeout "$outer_timeout" "$PROBE" "$@"
